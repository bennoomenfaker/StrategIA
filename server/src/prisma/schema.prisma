generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserType {
  INDIVIDUEL
  ORGANISATION
}

enum UserStatus {
  ACTIF
  INACTIF
  SUSPENDU
}

enum OrganizationRole {
  OWNER
  TEAM_MEMBER
  VIEWER
}

enum MemberStatus {
  ACTIVE
  PENDING
  INACTIVE
}

// ==================== STRATEGIC INTELLIGENCE ENUMS ====================

enum VeilleType {
  TECHNOLOGIQUE
  CONCURRENTIELLE
  COMMERCIALE
  REGLEMENTAIRE
  STRATEGIQUE
  E_REPUTATION
  SCIENTIFIQUE
  GEOPOLITIQUE
  ENVIRONNEMENTALE
  SECURITAIRE
  SOCIETALE
  CUSTOM
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum HypothesisStatus {
  OPEN
  IN_PROGRESS
  VALIDATED
  INVALIDATED
  PENDING_REVIEW
}

enum ValidationStatus {
  PENDING
  SUPPORTED
  CONTRADICTED
  UNCERTAIN
}

enum PerimeterType {
  GEOGRAPHIC
  SECTORIAL
  TEMPORAL
  ORGANIZATIONAL
  TECHNOLOGICAL
}

enum InsightType {
  OPPORTUNITY
  THREAT
  TREND
  SIGNAL_FAIBLE
  CONFIRMATION
  ALERT
  INFORMATION
}

enum RecommendationPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RecommendationStatus {
  DRAFT
  PROPOSED
  APPROVED
  REJECTED
  IMPLEMENTED
}

enum DecisionStatus {
  PENDING
  TAKEN
  DEFERRED
  CANCELLED
}

enum SignalStrength {
  FAIBLE
  MOYEN
  FORT
  CONFIRME
}

enum SourceCredibility {
  NON_VERIFIE
  FAIBLE
  MOYENNE
  ELEVEE
  OFFICIELLE
}

enum AISuggestionType {
  PROBLEMATIQUE
  OBJECTIF
  AXE
  HYPOTHESE
  QUESTION
  KEYWORD
  SOURCE
  PERIMETER
}

enum Frequency {
  ON_DEMAND
  DAILY
  WEEKLY
  MONTHLY
}

enum SourceType {
  RSS
  WEB
  API
  PDF
}

enum KeywordType {
  INCLUDE
  EXCLUDE
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRY
}

// ==================== AUTH & USERS ====================

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  nom           String
  password      String
  type          UserType
  status        UserStatus    @default(ACTIF)
  refreshToken  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  ownedProjects       Project[]           @relation("OwnedProjects")
  organizations       OrganizationMember[]
  ownedOrganizations  Organization[]      @relation("Owner")
  activityLogs        ActivityLog[]
  hypotheses          Hypothesis[]        @relation("UserHypotheses")
  collectedRawItems   RawItem[]           @relation("CollectedRawItems")
  validatedHypotheses Hypothesis[]        @relation("ValidatedBy")
  insights            Insight[]
  recommendations     Recommendation[]
  decisions           StrategicDecision[]
  refreshTokens       RefreshToken[]

  @@index([email])
  @@index([type])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ==================== ORGANIZATIONS ====================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  owner     User     @relation("Owner", fields: [ownerId], references: [id])
  logo      String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  OrganizationMember[]
  projects Project[]

  @@index([slug])
  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  role           OrganizationRole
  status         MemberStatus     @default(ACTIVE)
  invitedBy      String?
  joinedAt       DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("organization_members")
}

// ==================== PROJECTS (CORE ENTITY) ====================

model Project {
  id               String        @id @default(cuid())
  name             String
  description      String?       @db.Text
  slug             String        @unique
  veilleType       VeilleType    @default(CUSTOM)
  status           ProjectStatus @default(DRAFT)

  // === Strategic context (NEW) ===
  problematic      String?       @db.Text
  context          String?       @db.Text
  expectedDecision String?       @db.Text

  startDate        DateTime?
  endDate          DateTime?
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId      String?
  ownerUser        User?         @relation("OwnedProjects", fields: [ownerUserId], references: [id])
  folderId         String?
  closedAt         DateTime?
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  objectives      Objective[]
  perimeters      Perimeter[]
  rawItems        RawItem[]
  insights        Insight[]
  recommendations Recommendation[]
  decisions       StrategicDecision[]
  signals         Signal[]
  trends          Trend[]
  aiSuggestions   AISuggestion[]

  @@index([organizationId])
  @@index([ownerUserId])
  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

// ==================== STRATEGIC STRUCTURE ====================

model Objective {
  id          String   @id @default(cuid())
  content     String   @db.Text
  priority    Int      @default(1)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  axes Axis[]

  @@index([projectId])
  @@index([priority])
  @@map("objectives")
}

model Axis {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  priority    Int       @default(1)
  objectiveId String
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hypotheses Hypothesis[]

  @@index([objectiveId])
  @@index([priority])
  @@map("axes")
}

model Hypothesis {
  id              String           @id @default(cuid())
  content         String           @db.Text
  priority        Int              @default(1)
  status          HypothesisStatus @default(OPEN)
  validationScore Float?
  validatedAt     DateTime?
  validatedBy     String?
  validator       User?            @relation("ValidatedBy", fields: [validatedBy], references: [id])
  axisId          String
  axis            Axis             @relation(fields: [axisId], references: [id], onDelete: Cascade)
  createdBy       String?
  creator         User?            @relation("UserHypotheses", fields: [createdBy], references: [id])

  // Strategic enrichment (S7.5)
  scenario            String?          @db.Text
  timeframe           String?
  confidenceBefore    Float?
  confidenceAfter     Float?
  evidenceCount       Int              @default(0)
  contradictionCount  Int              @default(0)
  supportCount        Int              @default(0)
  lastEvaluatedAt     DateTime?
  stabilityScore      Float?           @default(0)
  validationStatus    ValidationStatus @default(PENDING)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  perimeters      HypothesisPerimeter[]
  collectionPlans CollectionPlan[]
  insights        Insight[]
  signals         Signal[]

  @@index([axisId])
  @@index([status])
  @@index([priority])
  @@index([validationStatus])
  @@map("hypotheses")
}

// ==================== PERIMETERS (HIERARCHICAL) ====================

model Perimeter {
  id          String         @id @default(cuid())
  name        String
  description String?        @db.Text
  type        PerimeterType
  projectId   String
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     Perimeter?     @relation("ParentChild", fields: [parentId], references: [id])
  children   Perimeter[]    @relation("ParentChild")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  hypothesisLinks HypothesisPerimeter[]

  @@index([projectId])
  @@index([parentId])
  @@index([projectId, parentId])
  @@index([type])
  @@map("perimeters")
}

model HypothesisPerimeter {
  id           String     @id @default(cuid())
  hypothesisId String
  hypothesis   Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  perimeterId  String
  perimeter    Perimeter  @relation(fields: [perimeterId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([hypothesisId, perimeterId])
  @@index([hypothesisId])
  @@index([perimeterId])
  @@map("hypothesis_perimeters")
}

// ==================== INSIGHTS & ANALYSIS LAYER ====================

model Insight {
  id            String       @id @default(cuid())
  title         String
  content       String       @db.Text
  type          InsightType  @default(INFORMATION)
  confidence    Float?       @default(0)

  // Source linkage
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hypothesisId  String?
  hypothesis    Hypothesis?  @relation(fields: [hypothesisId], references: [id])
  sourceItemId  String?

  // Strategic value
  impactScore   Float?       @default(0)
  urgencyScore  Float?       @default(0)
  isSignal      Boolean      @default(false)
  tags          String[]
  metadata      Json?

  createdBy     String?
  creator       User?        @relation(fields: [createdBy], references: [id])
  validatedAt   DateTime?
  validatedBy   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  recommendations Recommendation[]

  @@index([projectId])
  @@index([hypothesisId])
  @@index([type])
  @@index([createdAt])
  @@map("insights")
}

model Recommendation {
  id               String                 @id @default(cuid())
  title            String
  content          String                 @db.Text
  priority         RecommendationPriority @default(MEDIUM)
  status           RecommendationStatus   @default(DRAFT)

  // Source linkage
  insightId        String
  insight          Insight                @relation(fields: [insightId], references: [id], onDelete: Cascade)
  projectId        String
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Decision linkage
  decisionId       String?
  decision         StrategicDecision?     @relation(fields: [decisionId], references: [id])

  // Impact
  expectedImpact   String?                @db.Text
  resourcesNeeded  String?                @db.Text
  risks            String?                @db.Text
  deadline         DateTime?
  tags             String[]
  metadata         Json?

  createdBy        String?
  creator          User?                  @relation(fields: [createdBy], references: [id])
  implementedAt    DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([insightId])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@map("recommendations")
}

model StrategicDecision {
  id               String         @id @default(cuid())
  title            String
  description      String?        @db.Text
  status           DecisionStatus @default(PENDING)

  // Context
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recommendations  Recommendation[]
  relatedSignals   String[]

  // Decision attributes
  options          Json?
  selectedOption   String?        @db.Text
  rationale        String?        @db.Text
  expectedOutcome  String?        @db.Text
  actualOutcome    String?        @db.Text
  decisionDate     DateTime?
  reviewDate       DateTime?
  tags             String[]
  metadata         Json?

  createdBy        String?
  creator          User?          @relation(fields: [createdBy], references: [id])
  approvedBy       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([decisionDate])
  @@map("strategic_decisions")
}

// ==================== SIGNALS & TRENDS ====================

model Signal {
  id            String        @id @default(cuid())
  title         String
  description   String        @db.Text
  strength      SignalStrength @default(FAIBLE)

  // Context
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hypothesisId  String?
  hypothesis    Hypothesis?   @relation(fields: [hypothesisId], references: [id])
  sourceItemId  String?

  // Signal intelligence
  category      String?
  sourceUrl     String?       @db.Text
  firstDetected DateTime      @default(now())
  lastDetected  DateTime      @default(now())
  detectionCount Int          @default(1)
  relatedSignals String[]
  tags          String[]
  metadata      Json?

  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([projectId])
  @@index([hypothesisId])
  @@index([strength])
  @@index([firstDetected])
  @@map("signals")
}

model Trend {
  id            String        @id @default(cuid())
  name          String
  description   String        @db.Text
  direction     String?       // ascending, descending, stable, emerging
  momentum      Float?        @default(0)

  // Context
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Trend intelligence
  category      String?
  keywords      String[]
  relatedSignals String[]
  confidence    Float?        @default(0)
  firstDetected DateTime      @default(now())
  lastDetected  DateTime      @default(now())
  dataPoints    Json?
  tags          String[]
  metadata      Json?

  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([projectId])
  @@index([direction])
  @@index([momentum])
  @@index([firstDetected])
  @@map("trends")
}

// ==================== AI ASSISTANT (SNIPPETS & SUGGESTIONS) ====================

model SnippetTemplate {
  id            String           @id @default(cuid())
  type          AISuggestionType
  title         String
  content       String           @db.Text
  description   String?          @db.Text
  category      String?
  tags          String[]
  usageCount    Int              @default(0)
  isActive      Boolean          @default(true)
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  suggestions   AISuggestion[]

  @@index([type])
  @@index([isActive])
  @@index([usageCount])
  @@map("snippet_templates")
}

model AISuggestion {
  id            String           @id @default(cuid())
  type          AISuggestionType
  content       String           @db.Text
  context       Json?            // Stores the context that generated this suggestion

  // Linkage
  projectId     String?
  project       Project?         @relation(fields: [projectId], references: [id])
  templateId    String?
  template      SnippetTemplate? @relation(fields: [templateId], references: [id])

  // UX state
  isUsed        Boolean          @default(false)
  isSaved       Boolean          @default(false)
  isGenerated   Boolean          @default(true)
  score         Float?           @default(0)
  metadata      Json?
  createdAt     DateTime         @default(now())

  @@index([type])
  @@index([projectId])
  @@index([createdAt])
  @@map("ai_suggestions")
}

// ==================== COLLECTION PLANS (CORE INNOVATION) ====================

model CollectionPlan {
  id                    String     @id @default(cuid())
  question              String     @db.Text
  frequency             Frequency  @default(DAILY)
  cronExpression        String?
  collectionStartDate   DateTime?
  collectionEndDate     DateTime?
  isActive              Boolean    @default(true)
  lastRunAt             DateTime?
  nextRunAt             DateTime?
  hypothesisId          String
  hypothesis            Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  sources  CollectionPlanSource[]
  keywords CollectionPlanKeyword[]
  rawItems RawItem[]
  jobs     CollectionJob[]

  @@index([hypothesisId])
  @@index([isActive])
  @@index([nextRunAt])
  @@index([frequency])
  @@map("collection_plans")
}

model CollectionPlanSource {
  id               String         @id @default(cuid())
  collectionPlanId String
  collectionPlan   CollectionPlan @relation(fields: [collectionPlanId], references: [id], onDelete: Cascade)
  sourceType       SourceType
  sourceLabel      String
  sourceUrl        String         @db.Text
  isActive         Boolean        @default(true)
  lastFetchedAt    DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([collectionPlanId, sourceUrl])
  @@index([collectionPlanId])
  @@index([sourceType])
  @@index([isActive])
  @@map("collection_plan_sources")
}

model CollectionPlanKeyword {
  id               String         @id @default(cuid())
  collectionPlanId String
  collectionPlan   CollectionPlan @relation(fields: [collectionPlanId], references: [id], onDelete: Cascade)
  keyword          String
  keywordType      KeywordType    @default(INCLUDE)
  createdAt        DateTime       @default(now())

  @@unique([collectionPlanId, keyword])
  @@index([collectionPlanId])
  @@index([keyword])
  @@index([keywordType])
  @@map("collection_plan_keywords")
}

// ==================== RAW DATA STORAGE ====================

model RawItem {
  id               String         @id @default(cuid())
  title            String?
  contentRaw       String?        @db.Text
  contentCleaned   String?        @db.Text
  summary          String?        @db.Text
  sourceType       SourceType
  sourceUrl        String         @db.Text
  sourceName       String?
  publishedAt      DateTime?
  fetchedAt        DateTime       @default(now())
  hash             String
  isDuplicate      Boolean        @default(false)
  duplicateOfId    String?
  duplicateOf      RawItem?       @relation("RawItemDuplicate", fields: [duplicateOfId], references: [id])
  duplicates       RawItem[]      @relation("RawItemDuplicate")
  language         String?
  wordCount        Int?
  metadata         Json?
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collectionPlanId String
  collectionPlan   CollectionPlan @relation(fields: [collectionPlanId], references: [id], onDelete: Cascade)
  collectedBy      String?
  collector        User?          @relation("CollectedRawItems", fields: [collectedBy], references: [id])
  processedAt      DateTime?
  createdAt        DateTime       @default(now())

  entities        Json?
  classification  String?
  sentimentScore  Float?

  @@unique([hash, projectId])
  @@index([projectId])
  @@index([collectionPlanId])
  @@index([sourceType])
  @@index([publishedAt])
  @@index([fetchedAt])
  @@index([isDuplicate])
  @@index([projectId, createdAt])
  @@index([collectionPlanId, fetchedAt])
  @@index([hash])
  @@map("raw_items")
}

// ==================== COLLECTION JOBS (QUEUE) ====================

model CollectionJob {
  id               String         @id @default(cuid())
  collectionPlanId String
  collectionPlan   CollectionPlan @relation(fields: [collectionPlanId], references: [id], onDelete: Cascade)
  status           JobStatus      @default(PENDING)
  itemsFound       Int            @default(0)
  itemsStored      Int            @default(0)
  errorMessage     String?        @db.Text
  startedAt        DateTime?
  completedAt      DateTime?
  retryCount       Int            @default(0)
  createdAt        DateTime       @default(now())

  @@index([collectionPlanId])
  @@index([status])
  @@index([createdAt])
  @@map("collection_jobs")
}
